general {
  colors = true
  interval = 5
  markup = "pango"
}

order += "ethernet _first_"
order += "run_watch VPNC"
order += "path_exists VPN"
order += "disk /"
order += "disk /home"
order += "memory"
order += "load"
order += "tztime locald"
order += "tztime moscow"
order += "tztime local"

ethernet _first_ {
        format_up = "E: %ip (%speed)"
        format_down = "E: down"
}

run_watch VPNC {
        # file containing the PID of a vpnc process
        pidfile = "/var/run/vpnc/pid"
}

path_exists VPN {
        # path exists when a VPN tunnel launched by nmcli/nm-applet is active
        path = "/proc/sys/net/ipv4/conf/tun0"
}

tztime locald {
        format = "<span color='#5ab5e2'>%Y-%m-%d</span>"
        timezone = "Asia/Yekaterinburg"
}

tztime local {
        format = "<span color='#5ab5e2'>%H:%M:%S %Z</span>"
        timezone = "Asia/Yekaterinburg"
}

tztime moscow {
        format = "<span color='#5ab5e2'>%H:%M:%S %Z</span>"
        timezone = "Europe/Moscow"
}

load {
        format = "CPU %5min"
}

memory {
        format = "MEM %used"
        threshold_degraded = "10%"
        format_degraded = "MEMORY: %free"
}

disk "/" {
        format = "Root %free"
}

disk "/home" {
        format = "Home %free"
}

